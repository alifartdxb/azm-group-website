# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in the values below to configure the app.

# -----------------------------------------------------------------------------
# Nodemailer SMTP Configuration (For Contact Form)
# -----------------------------------------------------------------------------
# Hostinger SMTP (or your email provider)
SMTP_HOST=smtp.hostinger.com

# SMTP Port (Usually 465 for secure, 587 for TLS)
SMTP_PORT=465

# SMTP Secure (true for 465, false for 587)
SMTP_SECURE=true

# SMTP Username (The email address you are sending FROM)
SMTP_USER=noreply@alzahrabm.com

# SMTP Password (App password or account password)
SMTP_PASS=your_email_password_here

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# The email address that will receive the contact form submissions
CONTACT_EMAIL=office@alzahrabm.com

# The timezone for logs (optional)
TZ=Asia/Dubai
